{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "recreateWhen": "always",
  "minimumReleaseAge": "7 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "rebaseWhen": "behind-base-branch",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "extends": ["config:recommended", "mergeConfidence:all-badges"],
  "enabledManagers": [
    "kustomize",
    "kubernetes",
    "argocd",
    "helm-values",
    "custom.regex"
  ],
  "kustomize": {
    "managerFilePatterns": ["(^|/)kustomization\\.ya?ml$"]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/^infrastructure/.+\\.ya?ml$/",
      "/^user-apps/.+\\.ya?ml$/",
      "/^monitoring/.+\\.ya?ml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": ["/^infrastructure\\/controllers\\/argocd\\/apps\\/.*\\.ya?ml$/"]
  },
  "helm-values": {
    "enabled": true,
    "managerFilePatterns": [
      "/^infrastructure/.+/values\\.yaml$/",
      "/^user-apps/.+/values\\.yaml$/",
      "/^monitoring/.+/values\\.yaml$/"
    ]
  },
  "packageRules": [
    {
    "matchUpdateTypes": ["patch"],
    "automerge": true,
    "automergeType": "branch"
    },
    {
    "matchUpdateTypes": ["minor", "major"],
    "automerge": false,
    "prCreation": "immediate"
    },
    {
      "matchFileNames": [
        "infrastructure/controllers/argocd/**", 
        "infrastructure/databases/cloudnative-pg/**", 
        "infrastructure/databases/cloudnative-pg-apps-databases/**",
        "infrastructure/networking/cilium/**",
        "infrastructure/storage/longhorn/**"],
      "automerge": false
    },
    {
      "matchFileNames": [
        "infrastructure/databases/cloudnative-pg/**"
      ],
      "groupName": "CNPG Stack"
    },
    {
      "matchFileNames": [
        "infrastructure/controllers/sealed-secrets/**"
      ],
      "groupName": "Sealed Secrets"
    },
    {
      "matchFileNames": [
        "infrastructure/databases/redis-operator/**"
      ],
      "groupName": "Redis Operator"
    },
    {
      "matchFileNames": [
        "monitoring/goti-stack/**"
      ],
      "groupName": "Gotify Stack"
    },
    {
      "matchDepNames": [
        "firefly-iii/firefly-iii",
        "firefly-iii/data-importer"
      ],
      "groupName": "FireflyIII",
      "matchDatasources": [
        "github-releases"
      ]
    },
    {
      "matchDepNames": [
        "firefly-iii/firefly-iii",
        "firefly-iii/data-importer"
      ],
      "matchDatasources": [
        "docker"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "user-apps/miscellaneous/karakeep/**"
      ],
      "groupName": "Karakeep"
    },
    {
      "matchFileNames": [
        "user-apps/miscellaneous/changedetection/**"
      ],
      "groupName": "Changedetection"
    },
    {
      "matchFileNames": [
        "user-apps/miscellaneous/paperless/**"
      ],
      "groupName": "Paperless"
    }
  ],
  "customManagers": [
    {
      "description": "CloudNative PG Barman plugin manifest",
      "customType": "regex",
      "managerFilePatterns": [
        "/infrastructure/databases/cloudnative-pg/barman-plugin/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "https://github\\.com/cloudnative-pg/plugin-barman-cloud/releases/download/v(?<currentValue>[^/]+)/manifest\\.yaml"
      ],
      "depNameTemplate": "cloudnative-pg/plugin-barman-cloud",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "description": "FireflyIII core image via GitHub releases",
      "customType": "regex",
      "managerFilePatterns": [
        "/user-apps/miscellaneous/fireflyiii/core/deployment\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s+(?<depName>fireflyiii/core):version-(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "firefly-iii/firefly-iii",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "description": "FireflyIII importer via GitHub releases",
      "customType": "regex",
      "managerFilePatterns": [
        "/user-apps/miscellaneous/fireflyiii/importer/deployment\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s+(?<depName>fireflyiii/data-importer):version-(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "firefly-iii/data-importer",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "description": "Sealed Secrets CRD version (GitHub Releases)",
      "customType": "regex",
      "managerFilePatterns": [
        "/infrastructure/controllers/sealed-secrets/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "https://raw\\.githubusercontent\\.com/bitnami-labs/sealed-secrets/v(?<currentValue>[^/]+)/helm/sealed-secrets/crds/bitnami\\.com_sealedsecrets\\.yaml"
      ],
      "depNameTemplate": "bitnami-labs/sealed-secrets",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Redis Operator CRD version (GitHub Releases)",
      "customType": "regex",
      "managerFilePatterns": [
        "/infrastructure/databases/redis-operator/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "https://raw\\.githubusercontent\\.com/OT-CONTAINER-KIT/redis-operator/refs/tags/v(?<currentValue>[^/]+)/config/crd/bases/redis\\.redis\\.opstreelabs\\.in_[^\\s]+\\.yaml"
      ],
      "depNameTemplate": "OT-CONTAINER-KIT/redis-operator",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Gateway API YAML versions in README",
      "customType": "regex",
      "managerFilePatterns": ["/README\\.md$/"],
      "matchStrings": [
        "https://github\\.com/kubernetes-sigs/gateway-api/releases/download/v(?<currentValue>[^/]+)/standard-install\\.yaml",
        "https://github\\.com/kubernetes-sigs/gateway-api/releases/download/v(?<currentValue>[^/]+)/experimental-install\\.yaml"
      ],
      "depNameTemplate": "kubernetes-sigs/gateway-api",
      "datasourceTemplate": "github-releases"
    }
  ]
}
